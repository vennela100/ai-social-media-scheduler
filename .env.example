# Copy this file to ".env" and fill in real values. .env is gitignored.
# In production, set these as Render env vars and GitHub repo Secrets instead.

# --- Django core ---
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Full origins for CSRF, comma-separated, e.g. https://yourapp.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- Database (Neon Postgres) ---
# Leave blank to use local SQLite. Paste the Neon connection string to use Postgres.
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# --- Token encryption (Phase 3+) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# --- Cloudinary (Phase 1) ---
CLOUDINARY_URL=

# --- Gemini (Phase 2) ---
GEMINI_API_KEY=

# --- YouTube / Google OAuth (Phase 3) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Instagram / Meta (Phase 5) ---
META_APP_ID=
META_APP_SECRET=

# --- LinkedIn (Phase 6) ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Failure notifications (Phase 4) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
